# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# LLM Provider: "bedrock" | "openai" | "rule_based"
LLM_PROVIDER=rule_based
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# OpenAI (optional fallback)
OPENAI_API_KEY=

# Feature flags
USE_TEXTRACT=false
USE_BEDROCK_EMBEDDINGS=false
USE_AWS_VOICE=false

# Auth
SECRET_KEY=soochna-setu-secret-key-change-in-production

# S3 (for document storage in production)
S3_DOCUMENT_BUCKET=soochna-setu-documents
S3_AUDIO_BUCKET=soochna-setu-audio
